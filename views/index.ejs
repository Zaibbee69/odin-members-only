<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clubhouse</title>
    <style>
        :root {
            --color-bg: #0f1420;
            --color-bg-soft: #161d2e;
            --color-surface: #1c2436;
            --color-surface-alt: #212b40;
            --color-border: #2b3550;
            --color-primary: #6c5ce7;
            --color-primary-hover: #5b4bd1;
            --color-primary-soft: rgba(108, 92, 231, 0.15);
            --color-accent: #00d2a8;
            --color-danger: #e74c3c;
            --color-danger-hover: #cf3f30;
            --color-text: #eef0f5;
            --color-text-muted: #9aa4bf;
            --color-text-dim: #6b7590;
            --radius-sm: 8px;
            --radius-md: 14px;
            --radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.25);
            --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.35);
            --transition: all 0.2s ease;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
        }

        body {
            background: radial-gradient(circle at top, var(--color-bg-soft) 0%, var(--color-bg) 60%);
            color: var(--color-text);
            font-family: 'Segoe UI', system-ui, -apple-system, Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        a {
            color: var(--color-accent);
            text-decoration: none;
            transition: var(--transition);
        }

        a:hover {
            color: var(--color-primary);
        }

        hr {
            display: none;
        }

        /* ---------- Layout ---------- */
        .page-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .container {
            width: 100%;
            max-width: 780px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* ---------- Navbar ---------- */
        .navbar {
            background: rgba(28, 36, 54, 0.85);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--color-border);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-inner {
            max-width: 780px;
            margin: 0 auto;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--color-text);
            letter-spacing: 0.3px;
        }

        .brand-mark {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            box-shadow: var(--shadow-sm);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .nav-greeting {
            color: var(--color-text-muted);
            font-size: 0.92rem;
            margin-right: 4px;
        }

        .nav-greeting strong {
            color: var(--color-text);
        }

        /* ---------- Hero ---------- */
        .hero {
            padding: 48px 20px 28px;
            text-align: center;
        }

        .hero h1 {
            font-size: 2rem;
            margin: 0 0 8px;
            font-weight: 800;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, #fff, var(--color-text-muted));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-sub {
            color: var(--color-text-muted);
            font-size: 1rem;
            margin: 0 auto 20px;
            max-width: 520px;
        }

        .hero-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 16px;
        }

        /* ---------- Buttons ---------- */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 10px 20px;
            border-radius: var(--radius-sm);
            font-size: 0.92rem;
            font-weight: 600;
            border: 1px solid transparent;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            line-height: 1.2;
        }

        .btn-primary {
            background: var(--color-primary);
            color: #fff;
            box-shadow: var(--shadow-sm);
        }

        .btn-primary:hover {
            background: var(--color-primary-hover);
            transform: translateY(-1px);
            color: #fff;
        }

        .btn-outline {
            background: transparent;
            color: var(--color-text);
            border-color: var(--color-border);
        }

        .btn-outline:hover {
            background: var(--color-surface-alt);
            border-color: var(--color-primary);
            color: var(--color-text);
        }

        .btn-accent {
            background: var(--color-accent);
            color: #06231c;
        }

        .btn-accent:hover {
            background: #00b892;
            transform: translateY(-1px);
            color: #06231c;
        }

        .btn-danger {
            background: transparent;
            color: var(--color-danger);
            border-color: rgba(231, 76, 60, 0.4);
            padding: 6px 14px;
            font-size: 0.82rem;
        }

        .btn-danger:hover {
            background: var(--color-danger);
            border-color: var(--color-danger);
            color: #fff;
        }

        .btn-sm {
            padding: 7px 14px;
            font-size: 0.85rem;
        }

        /* ---------- Info banner (logged out) ---------- */
        .info-banner {
            max-width: 780px;
            margin: 0 auto 24px;
            padding: 0 20px;
        }

        .info-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            padding: 20px 24px;
            text-align: center;
            box-shadow: var(--shadow-sm);
        }

        .info-card p {
            margin: 0 0 14px;
            color: var(--color-text-muted);
        }

        /* ---------- Section header ---------- */
        .section-header {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            padding: 8px 0 18px;
            border-bottom: 1px solid var(--color-border);
            margin-bottom: 22px;
        }

        .section-header h2 {
            font-size: 1.3rem;
            margin: 0;
            font-weight: 700;
        }

        .section-header .count {
            color: var(--color-text-dim);
            font-size: 0.85rem;
        }

        /* ---------- Messages ---------- */
        .messages-section {
            padding: 8px 20px 64px;
        }

        .message-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .message-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            padding: 20px 22px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
        }

        .message-card:hover {
            border-color: var(--color-primary);
            box-shadow: var(--shadow-md);
        }

        .message-card h3 {
            margin: 0 0 8px;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--color-text);
        }

        .message-body {
            margin: 0 0 14px;
            color: var(--color-text-muted);
            white-space: pre-wrap;
            word-break: break-word;
        }

        .message-meta {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            font-size: 0.85rem;
            color: var(--color-text-dim);
            padding-top: 10px;
            border-top: 1px dashed var(--color-border);
        }

        .meta-author {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--color-text-muted);
            font-weight: 600;
        }

        .avatar-dot {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
            display: inline-block;
        }

        .meta-dot {
            color: var(--color-text-dim);
        }

        .message-footer {
            display: flex;
            justify-content: flex-end;
            margin-top: 12px;
        }

        .locked-note {
            font-size: 0.82rem;
            color: var(--color-text-dim);
            font-style: italic;
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--color-text-dim);
            border: 1px dashed var(--color-border);
            border-radius: var(--radius-md);
        }

        /* ---------- Forms (delete) ---------- */
        form {
            margin: 0;
        }

        /* ---------- Footer ---------- */
        .site-footer {
            border-top: 1px solid var(--color-border);
            padding: 22px 20px;
            text-align: center;
            color: var(--color-text-dim);
            font-size: 0.85rem;
        }

        /* ---------- Responsive ---------- */
        @media (max-width: 600px) {
            .navbar-inner {
                justify-content: center;
                text-align: center;
            }

            .hero h1 {
                font-size: 1.6rem;
            }

            .message-card {
                padding: 16px 18px;
            }

            .section-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 4px;
            }
        }
    </style>
</head>
<body>

    <div class="page-wrapper">

        <nav class="navbar">
            <div class="navbar-inner">
                <div class="brand">
                    <span class="brand-mark">♣</span>
                    <span>Members Only</span>
                </div>

                <div class="nav-links">
                    <% if (user) { %>
                        <span class="nav-greeting">Hello, <strong><%= user.first_name %> <%= user.last_name %></strong></span>

                        <% if (!user.is_member) { %>
                            <a href="/join-club" class="btn btn-accent btn-sm">Join the Club</a>
                        <% } %>

                        <a href="/message" class="btn btn-primary btn-sm">Create Message</a>
                        <a href="/logout" class="btn btn-outline btn-sm">Logout</a>

                    <% } else { %>
                        <a href="/login" class="btn btn-outline btn-sm">Login</a>
                        <a href="/signup" class="btn btn-primary btn-sm">Signup</a>
                    <% } %>
                </div>
            </div>
        </nav>

        <header class="hero">
            <div class="container">
                <h1>Welcome to the Clubhouse</h1>
                <p class="hero-sub">A private space for members to share thoughts, stories, and conversation.</p>
            </div>
        </header>

        <% if (!user) { %>
            <div class="info-banner">
                <div class="info-card">
                    <p>Please log in to access the clubhouse.</p>
                    <div class="hero-actions">
                        <a href="/login" class="btn btn-outline">Login</a>
                        <a href="/signup" class="btn btn-primary">Signup</a>
                    </div>
                </div>
            </div>
        <% } %>

        <main class="messages-section">
            <div class="container">

                <div class="section-header">
                    <h2>Messages</h2>
                    <span class="count"><%= messages.length %> total</span>
                </div>

                <% if (messages.length === 0) { %>
                    <div class="empty-state">
                        No messages yet. Be the first to share something.
                    </div>
                <% } %>

                <div class="message-list">
                    <% messages.forEach(message => { %>

                        <div class="message-card">

                            <h3><%= message.title %></h3>

                            <p class="message-body"><%= message.message %></p>

                            <% if (user && user.is_member) { %>
                                <div class="message-meta">
                                    <span class="meta-author">
                                        <span class="avatar-dot"></span>
                                        <%= message.first_name %> <%= message.last_name %>
                                    </span>
                                    <span class="meta-dot">&bull;</span>
                                    <span><%= new Date(message.created_at).toLocaleString() %></span>
                                </div>
                            <% } %>

                            <% if (user && user.is_admin) { %>
                                <div class="message-footer">
                                    <form action="/message/<%= message.id %>/delete" method="POST">
                                        <button type="submit" class="btn btn-danger">Delete</button>
                                    </form>
                                </div>
                            <% } %>

                        </div>

                    <% }) %>
                </div>

            </div>
        </main>

        <footer class="site-footer">
            &copy; <%= new Date().getFullYear() %> Members Only Clubhouse. All rights reserved.
        </footer>

    </div>

</body>
</html>