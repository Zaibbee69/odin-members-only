<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join Club</title>
  </head>
  <body>
    <h1>Join a Club</h1>
    <form action="/join-club" method="POST">
      <label for="secret_code">Secret Code:</label>
      <input type="text" id="secret_code" name="secret_code" required />
      <button type="submit">Join Club</button>
    </form>
    <p>Hint: The secret code is "Avengers-Assemble"</p>
  </body>
</html>
